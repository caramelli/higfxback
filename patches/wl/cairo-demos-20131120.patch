# This file is part of HiGFXback

# requires
REQUIRES="cairo-build gdk-pixbuf-build gnome-backgrounds-build make-build"

PKG_CONFIG_PATH=/wl/share/pkgconfig pkg-config --exists --print-errors $REQUIRES || exit 1

# configure
rm -f kapow/kapow.o
rm -f png/star_and_ring
rm -f PS/write_png.h
PKG_CONFIG_PATH=/wl/lib/pkgconfig sh ./Configure --with-backgroundsdir=/share/backgrounds --with-demosdatadir=/wl/share/cairo-demos --prefix=/wl

# build
make
make -C kapow
make -C png
make -C PS

# install
install -d $DESTDIR/wl/bin
install bubble-demo $DESTDIR/wl/bin
install chart-demo $DESTDIR/wl/bin
install dragon-demo $DESTDIR/wl/bin
