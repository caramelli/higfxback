--- cairo-demos-20131120.orig/wayland_shm.c
+++ cairo-demos-20131120/wayland_shm.c
@@ -0,0 +1,141 @@
+#include <cairo.h>
+
+#include "demo.h"
+
+#include <stdlib.h>
+#include <string.h>
+#include <sys/mman.h>
+#include <wayland-client.h>
+
+struct wayland_shm_device {
+    struct device base;
+    struct framebuffer fb;
+
+    struct wl_display *display;
+    struct wl_registry *registry;
+    struct wl_output *output;
+    struct wl_compositor *compositor;
+    struct wl_shell *wl_shell;
+    struct wl_shm *shm;
+    struct wl_surface *surface;
+};
+
+static void
+destroy (struct framebuffer *fb)
+{
+}
+
+static void
+show (struct framebuffer *fb)
+{
+    struct wayland_shm_device *device = (struct wayland_shm_device *) fb->device;
+    wl_display_dispatch (device->display);
+}
+
+static struct framebuffer *
+get_fb (struct device *abstract_device)
+{
+    struct wayland_shm_device *device = (struct wayland_shm_device *) abstract_device;
+    return &device->fb;
+}
+
+static void wl_output_handle_geometry (void *data, struct wl_output *output, int x, int y, int physical_width, int physical_height, int subpixel, const char *make, const char *model, int transform)
+{
+}
+
+static void wl_output_handle_mode (void *data, struct wl_output *output, unsigned int flags, int width, int height, int refresh)
+{
+    struct wayland_shm_device *device = data;
+    device->base.width = width;
+    device->base.height = height;
+}
+
+static void wl_output_handle_done (void *data, struct wl_output *output)
+{
+}
+
+static void wl_output_handle_scale (void *data, struct wl_output *output, int factor)
+{
+}
+
+static struct wl_output_listener wl_output_listener = { wl_output_handle_geometry, wl_output_handle_mode, wl_output_handle_done, wl_output_handle_scale };
+
+static void wl_registry_handle_global (void *data, struct wl_registry *registry, unsigned int name, const char *interface, unsigned int version)
+{
+    struct wayland_shm_device *device = data;
+
+    if (!strcmp (interface, "wl_output")) {
+        device->output = wl_registry_bind (registry, name, &wl_output_interface, 1);
+        wl_output_add_listener (device->output, &wl_output_listener, device);
+    } else if (!strcmp (interface, "wl_compositor")) {
+        device->compositor = wl_registry_bind (registry, name, &wl_compositor_interface, 1);
+    } else if (!strcmp (interface, "wl_shell")) {
+        device->wl_shell = wl_registry_bind (registry, name, &wl_shell_interface, 1);
+    } else if (!strcmp (interface, "wl_shm")) {
+        device->shm = wl_registry_bind (registry, name, &wl_shm_interface, 1);
+    }
+}
+
+static void wl_registry_handle_global_remove (void *data, struct wl_registry *registry, unsigned int name)
+{
+}
+
+static struct wl_registry_listener wl_registry_listener = { wl_registry_handle_global, wl_registry_handle_global_remove };
+
+static struct wl_callback_listener wl_callback_listener;
+
+static void wl_callback_handle_done (void *data, struct wl_callback *callback, uint32_t time)
+{
+    struct wayland_shm_device *device = data;
+    wl_surface_damage (device->surface, 0, 0, device->base.width, device->base.height);
+    wl_callback_add_listener (wl_surface_frame(device->surface), &wl_callback_listener, device);
+    wl_surface_commit (device->surface);
+}
+
+static struct wl_callback_listener wl_callback_listener = { wl_callback_handle_done };
+
+struct device *
+wayland_shm_open (int argc, char **argv)
+{
+    struct wayland_shm_device *device;
+    struct wl_shell_surface *shell_surface;
+    char template[PATH_MAX];
+    int fd;
+    unsigned char *data;
+    struct wl_shm_pool *pool;
+    struct wl_buffer *buffer;
+
+    device = (struct wayland_shm_device *) malloc (sizeof (struct wayland_shm_device));
+    device->base.name = "wayland-shm";
+    device->base.get_framebuffer = get_fb;
+
+    device->display = wl_display_connect (NULL);
+    device->registry = wl_display_get_registry (device->display);
+    wl_registry_add_listener (device->registry, &wl_registry_listener, device);
+    wl_display_dispatch (device->display);
+    wl_display_roundtrip (device->display);
+
+    device_get_size (argc, argv, &device->base.width, &device->base.height);
+
+    device->surface = wl_compositor_create_surface (device->compositor);
+    shell_surface = wl_shell_get_shell_surface (device->wl_shell, device->surface);
+    wl_shell_surface_set_toplevel (shell_surface);
+    strcpy (template, "/tmp/XXXXXX");
+    fd = mkstemp (template);
+    ftruncate (fd, device->base.width * device->base.height * 4);
+    data = mmap (NULL, device->base.width * device->base.height * 4, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+    pool = wl_shm_create_pool (device->shm, fd, device->base.width * device->base.height * 4);
+    buffer = wl_shm_pool_create_buffer (pool, 0, device->base.width, device->base.height, device->base.width * 4, WL_SHM_FORMAT_XRGB8888);
+    wl_shm_pool_destroy (pool);
+    close (fd);
+    wl_surface_attach (device->surface, buffer, 0, 0);
+    wl_callback_handle_done (device, NULL, 0);
+    device->base.scanout = cairo_image_surface_create_for_data (data, CAIRO_FORMAT_ARGB32, device->base.width, device->base.height, device->base.width * 4);
+
+    device->fb.device = &device->base;
+    device->fb.surface = device->base.scanout;
+    device->fb.show = show;
+    device->fb.destroy = destroy;
+
+    return &device->base;
+}

