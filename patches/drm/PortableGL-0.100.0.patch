fi

# configure
rm -f glcommon/stb_*
rm -rf external/glm
rm -rf external/imgui
PKG_CONFIG_PATH=/drm/lib/pkgconfig premake5 --file=demos/premake5.lua --demosdatadir=/drm/share/PortableGL/media --with-stb-dir=/include/stb gmake
PKG_CONFIG_PATH=/drm/lib/pkgconfig premake5 --file=examples/premake5.lua --examplesdatadir=/drm/share/PortableGL/media --with-stb-dir=/include/stb gmake
PKG_CONFIG_PATH=/drm/lib/pkgconfig premake5 --file=testing/premake5.lua --testingdatadir=/drm/share/PortableGL/media --with-stb-dir=/include/stb gmake

# build
test $SDL2 && make -C demos
test $SDL2 && make -C examples
test $SDL2 && make -C testing

