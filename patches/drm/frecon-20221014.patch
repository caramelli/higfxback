# This file is part of HiGFXback

# requires
REQUIRES="libdrm-build libpng-build libtsm-build make-build"

PKG_CONFIG_PATH=/drm/share/pkgconfig pkg-config --exists --print-errors $REQUIRES || exit 1

# configure
PKG_CONFIG_PATH=/drm/lib/pkgconfig sh ./Configure --enable-lite --prefix=/drm

# build
make

# install
install -d $DESTDIR/drm/bin
install frecon-lite $DESTDIR/drm/bin/frecon

# build.pc
install -d $DESTDIR/drm/share/pkgconfig
cat > $DESTDIR/drm/share/pkgconfig/frecon-build.pc << EOF
Name: frecon
Version: 20221014
Description: KMS/DRM terminal emulator
Requires: $REQUIRES

exec=\\
/drm/bin/frecon
EOF

exit

# patch
--- frecon-20221014.orig/Configure
+++ frecon-20221014/Configure
@@ -0,0 +1,25 @@
+#!/bin/sh
+
+PREFIX=/usr/local
+
+FRECON_LITE=0
+
+while [ $# != 0 ]; do
+  case $1 in
+    --prefix=*) PREFIX=${1#*=};;
+    --enable-lite) FRECON_LITE=1;;
+    *) echo "Unknown option: '$1'"; exit 1;;
+  esac
+  shift
+done
+
+sed -i "/^PREFIX/s|=.*|= $PREFIX|" Makefile
+
+sed -i "/^FRECON_LITE/s|=.*|= $FRECON_LITE|" Makefile
+
+test $PKG_CONFIG || PKG_CONFIG=pkg-config
+if test $PKG_CONFIG_PATH; then
+  sed -i "s|PKG_CONFIG.*|PKG_CONFIG,PKG_CONFIG_PATH=$PKG_CONFIG_PATH $PKG_CONFIG))|" common.mk
+else
+  sed -i "s|PKG_CONFIG.*|PKG_CONFIG,$PKG_CONFIG))|" common.mk
+fi
